# --- Web signaling server configuration ------------------------------------
# Copy to `.env`. Loaded automatically by server.js via process.loadEnvFile().
# Ambient env vars (e.g. from a PM2 ecosystem file) take precedence.

# Port the signaling server / static site listens on.
PORT=3000

# Set to 1 only behind a trusted reverse proxy that sets X-Forwarded-For.
TRUST_PROXY=0

# --- TURN credentials (proxied to the ../turn service) ---------------------
# The browser fetches GET /turn-credentials from this server; the server mints a
# time-based one-time code here (never in the browser) and redeems it at the
# ../turn credential service for short-lived coturn credentials.

# Base URL of the ../turn credential service.
TURN_AUTH_URL=http://localhost:8080

# Shared TOTP secret. MUST match the ../turn service's TOTP_SECRET.
TURN_AUTH_TOTP_SECRET=change-me-shared-totp-secret

# Must match the ../turn service's TOTP settings.
TOTP_PERIOD=30
TOTP_DIGITS=6
